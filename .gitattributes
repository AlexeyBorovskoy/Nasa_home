# NASA Home Cloud — force LF line endings for all shell scripts and configs
# Without this, git on Windows converts LF→CRLF, which breaks bash shebangs
# (#!/usr/bin/env bash\r → systemd 203/EXEC "No such file or directory")

# Shell scripts: always LF + preserve exec bit
# Note: after git add on Windows, run: git update-index --chmod=+x <file.sh>
*.sh        text eol=lf
*.bash      text eol=lf

# Systemd units: always LF
*.service   text eol=lf
*.timer     text eol=lf
*.socket    text eol=lf

# Config and env files: always LF
*.env       text eol=lf
*.conf      text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf

# Python scripts: always LF
*.py        text eol=lf

# Markdown and text: auto
*.md        text eol=lf
*.txt       text eol=lf

# Windows-native files: CRLF
*.docx      binary
*.odt       binary

# Binary files: no conversion
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.zip       binary
*.tar.gz    binary
