[Unit]
Description=NASA USB SSD Pre-boot Power Cycle (port 2 power cycle before mount)
Documentation=https://github.com/AlexeyBorovskoy/Nasa_home
# Запускаем ДО монтирования SSD — power cycle порта 2 для чистой инициализации
Before=jetson-nas-mount.service
After=local-fs.target
DefaultDependencies=no

[Service]
Type=oneshot
RemainAfterExit=no
ExecStart=/usr/local/sbin/nasa-usb-preboot.sh
StandardOutput=journal
StandardError=journal
SyslogIdentifier=nasa-usb-preboot

[Install]
WantedBy=multi-user.target
