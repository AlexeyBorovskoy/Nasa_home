[Unit]
Description=NASA Home Cloud — database backup (pg_dump)
Documentation=https://github.com/AlexeyBorovskoy/Nasa_home
After=network-online.target docker.service
Wants=network-online.target
Requires=docker.service

[Service]
Type=oneshot
# Adjust NASA_PROJECT_DIR if repo is not at /home/admin/nasa
Environment=NASA_PROJECT_DIR=/home/admin/nasa
ExecStart=/bin/bash -c "${NASA_PROJECT_DIR}/scripts/backup/backup_databases.sh"
User=admin
# On failure try once more after 5 min, then give up
Restart=on-failure
RestartSec=5min
# Log to journal; retrieve with: journalctl -u nasa-backup.service
StandardOutput=journal
StandardError=journal
SyslogIdentifier=nasa-backup
