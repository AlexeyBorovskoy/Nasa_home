[Unit]
Description=NASA USB SSD Recovery Watchdog Timer
Requires=nasa-usb-watchdog.service

[Timer]
# Первый запуск через 2 минуты после загрузки (быстрее обнаруживаем проблему)
# NB: nasa-usb-preboot.service делает power cycle ДО монтирования,
# поэтому 2min достаточно для проверки что SSD поднялся
OnBootSec=2min
# Затем каждые 3 минуты
OnUnitActiveSec=3min
# Не накапливать пропущенные срабатывания
AccuracySec=30s
Persistent=false

[Install]
WantedBy=timers.target
