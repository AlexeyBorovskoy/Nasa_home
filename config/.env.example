# ==========================================================
# Home Cloud Jetson public template
# Copy this file to .env and replace values locally.
# Never commit real .env to GitHub.
# ==========================================================

# General
TZ=Europe/Berlin
PUID=1000
PGID=1000

# Network
JETSON_LAN_IP=192.168.0.50
NEXTCLOUD_HOST=cloud.local
IMMICH_HOST=photos.local
LLM_GATEWAY_HOST=llm.local

# Storage
STORAGE_ROOT=/mnt/storage
NEXTCLOUD_DATA=/mnt/storage/nextcloud/data
IMMICH_UPLOAD_LOCATION=/mnt/storage/immich/library
IMMICH_DB_DATA_LOCATION=/mnt/storage/db/immich-postgres
NEXTCLOUD_DB_DATA=/mnt/storage/db/nextcloud-postgres
BACKUP_ROOT=/mnt/storage/backups

# Nextcloud
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=change_me
NEXTCLOUD_TRUSTED_DOMAINS=192.168.0.50 cloud.local
NEXTCLOUD_DB_NAME=nextcloud
NEXTCLOUD_DB_USER=nextcloud
NEXTCLOUD_DB_PASSWORD=change_me
POSTGRES_NEXTCLOUD_PASSWORD=change_me

# Immich
IMMICH_VERSION=release
IMMICH_DB_NAME=immich
IMMICH_DB_USER=immich
IMMICH_DB_PASSWORD=change_me
IMMICH_DISABLE_MACHINE_LEARNING=true

# Redis
REDIS_PASSWORD=change_me

# LLM Gateway / DeepSeek
LLM_PROVIDER=deepseek
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=replace_me
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_REASONER_MODEL=deepseek-v4-pro
LLM_DAILY_TOKEN_LIMIT=100000
LLM_MONTHLY_COST_LIMIT_USD=10
LLM_LOG_PROMPTS=false
LLM_LOG_RESPONSES=false
LLM_REDACT_PERSONAL_DATA=true
LLM_ALLOW_FILE_CONTENT_UPLOAD=false
LLM_ALLOW_IMAGE_ANALYSIS=false

# Optional future provider
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=replace_me
OPENAI_MODEL=gpt-5.5

# Backup
RESTIC_REPOSITORY=/mnt/storage/backups/restic-repo
RESTIC_PASSWORD=change_me
# Альтернатива: путь к файлу с паролем (приоритетнее, чем RESTIC_PASSWORD).
# RESTIC_PASSWORD_FILE=/root/.restic-password
BACKUP_RETENTION_DAILY=7
BACKUP_RETENTION_WEEKLY=4
BACKUP_RETENTION_MONTHLY=12

# Backup API (services/backup-api/, Stage 2 — Android-клиент восстановления)
# Сервис намеренно отключён в Stage 1 (не разворачивать на боевом Jetson до Stage 2).
BACKUP_API_PORT=8095
# Bearer-токен для авторизации Android-клиента (длинная случайная строка,
# например: openssl rand -hex 32).
BACKUP_API_TOKEN=change_me_long_random_token
# Корневая папка для пользовательских бэкапов с устройств.
BACKUP_API_STORAGE_ROOT=/mnt/storage/backups/devices
# Stage-флаг: 1 — реальный режим, 0 — mock (по умолчанию для Stage 1).
BACKUP_API_ENABLED=0
